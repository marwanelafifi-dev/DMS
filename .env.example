# Copy this file to `.env` and adjust as needed. NEVER commit the real .env.
# The same values work on Windows (local) and Ubuntu (exposure) — only hostnames
# for the tunnel differ, and those are set in Cloudflare, not here.

# --- PostgreSQL ---
POSTGRES_USER=dms_app
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_DB=dms
POSTGRES_PORT=5432

# --- MinIO (object storage) ---
MINIO_ROOT_USER=dms_minio
MINIO_ROOT_PASSWORD=change_me_dev_only
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Redis ---
REDIS_PORT=6379

# --- Application service ports (host side) ---
API_PORT=8080
OCR_PORT=8100
# NOTE: intentionally different from Vite's default dev-server port (5173) so
# `docker compose up` never silently shadows `npm run dev` on the same port.
WEB_PORT=5174

# --- Cloudflare Tunnel (Stage 2 / Ubuntu only) ---
# Create a tunnel in the Cloudflare Zero Trust dashboard and paste its token here.
CLOUDFLARE_TUNNEL_TOKEN=
